# Leave true for the complete, zero-dependency hackathon demo.
# Set false only after you have connected a Midnight DApp Connector wallet to the configured network.
VITE_DEMO_MODE=true

# Neon Auth: browser-safe URL from Neon Console → Auth → Configuration.
# On Vercel, the Neon integration supplies this variable automatically.
VITE_NEON_AUTH_URL=https://YOUR-PROJECT.auth.neon.tech

# Public address only — safe to paste and used for deployment readiness checks.
# This does NOT grant signing access. Your wallet signs browser transactions locally.
VITE_MIDNIGHT_WALLET_ADDRESS=PASTE_YOUR_FUNDED_MIDNIGHT_WALLET_ADDRESS_HERE
MIDNIGHT_WALLET_ADDRESS=PASTE_YOUR_FUNDED_MIDNIGHT_WALLET_ADDRESS_HERE
VITE_MIDNIGHT_CONTRACT_ADDRESS=PASTE_DEPLOYED_PAYSPLIP_CONTRACT_ADDRESS_HERE
VITE_MIDNIGHT_NETWORK_ID=preprod

# Midnight public-network defaults. Local development uses docker-compose.yml.
MIDNIGHT_NETWORK=preprod
MIDNIGHT_INDEXER_URL=https://indexer.preprod.midnight.network/api/v4/graphql
MIDNIGHT_INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v4/graphql/ws
MIDNIGHT_NODE_URL=https://rpc.preprod.midnight.network
MIDNIGHT_PROOF_SERVER_URL=http://127.0.0.1:6300
MIDNIGHT_FAUCET_URL=https://midnight-tmnight-preprod.nethermind.dev

# Never put a production wallet seed in a committed file. The headless deploy
# tool reads this only from your uncommitted .env when explicitly configured.
# MIDNIGHT_WALLET_SEED=
PRIVATE_STATE_PASSWORD=CHANGE_THIS_TO_A_LONG_LOCAL_PASSWORD
